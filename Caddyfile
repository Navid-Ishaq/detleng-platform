{$PLATFORM_ADDRESS::80} {
	encode zstd gzip

	redir /airflow /airflow/ 308
	# Airflow is prefix-aware when AIRFLOW__API__BASE_URL includes /airflow.
	# Keep the prefix; stripping it breaks Airflow 3 UI/API links.
	handle /airflow/* {
		reverse_proxy {$AIRFLOW_UPSTREAM} {
			header_up X-Forwarded-Prefix /airflow
		}
	}

	redir /postgresql /postgresql/ 308
	handle_path /postgresql/* {
		reverse_proxy pgadmin:80 {
			header_up X-Script-Name /postgresql
			header_up X-Forwarded-Prefix /postgresql
		}
	}

	redir /dbt /dbt/ 308
	handle_path /dbt/* {
		reverse_proxy dbt-docs:8080
	}

	respond /healthz `{"status":"ok","service":"detleng-platform"}` 200 {
		close
	}

	handle {
		root * /srv/platform
		try_files {path} {path}/ /index.html
		file_server
	}
}
