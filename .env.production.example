# Copy to .env on the production server.
PLATFORM_ADDRESS=platform.detleng.com
PLATFORM_HTTP_PORT=80
PLATFORM_HTTPS_PORT=443

# Use a private address reachable from the Caddy container. If Airflow runs on
# the same VM host, bind it to the Docker host gateway and block port 8080 at
# the public firewall.
AIRFLOW_UPSTREAM=host.docker.internal:8080
AIRFLOW_PORT=8080
AIRFLOW_COMMAND=

POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=postgres
DBT_POSTGRES_HOST=localhost

PGADMIN_DEFAULT_EMAIL=admin@detleng.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_TOO

DBT_PROJECT_DIR=
DBT_PROFILES_DIR=
DBT_COMMAND=
