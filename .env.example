# Local platform gateway
PLATFORM_HTTP_PORT=8088
PLATFORM_HTTPS_PORT=8443
# Caddy site address. Keep :80 locally. Use platform.detleng.com on a server.
PLATFORM_ADDRESS=:80

# Existing local services reached from Docker Desktop
AIRFLOW_UPSTREAM=host.docker.internal:8080
AIRFLOW_PORT=8080
# Optional absolute path when airflow is installed in a virtual environment.
AIRFLOW_COMMAND=
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=postgres
# dbt runs on the host, so it normally connects through localhost rather than
# Docker's host.docker.internal name.
DBT_POSTGRES_HOST=localhost

# pgAdmin login (not the PostgreSQL account)
PGADMIN_DEFAULT_EMAIL=info@detleng.local
PGADMIN_DEFAULT_PASSWORD=DLPlatform@2026

# Optional absolute path to an existing dbt project. Leave blank to use the
# empty integration-ready project under backend/dbt/project.
DBT_PROJECT_DIR=
DBT_PROFILES_DIR=
# Optional absolute path when dbt is installed in a virtual environment.
DBT_COMMAND=
